  "templates": {
    "parse_fn_namespace": "lum::fmt::detail",
    "parse_fn_signature": "Parse{0}( std::vector<FToken>& tokens, int32& i, FParseContext& ctx )",
    "parse_fn_body_open": "detail::ExpectOpeningBracket( tokens, i );",
    "parse_fn_var_name": "component",
    "parse_fn_field": "{0}.{1} = {2}( tokens, i );",
    "parse_fn_add": "ctx.mScene.mEntityMgr.AddComponent( ctx.mEntity, {0} );",
    "parse_fn_registry": "RegisterComponents( std::unordered_map<uint64, ParseFn>& {0} )",
    "parse_fn_while_expr": "InBlock( tokens, i )",
    "parse_fn_while_statement": "tokens[i].mValue == \"{0}\"",
    "parse_fn_token_check": "tokens[i].mType == TokenType::Parameter",

    "editor_fn_namespace": "lum",
    "editor_fn_signature": "DrawInspector{0}( ecs::MEntityManager& mgr, EntityID entity )",
    "editor_fn_comp_name": "component",
    "editor_fn_comp_getter": "auto* {0} = mgr.GetComponent<{1}>( entity );",
    "editor_fn_getter_check": "if(!{0}) return;",
    "editor_fn_registry": "RegisterEditorComponents( std::unordered_map<uint64, detail::EditorFn>& {0} )",

    "component_get_name_namespace": "lum::ecs::detail",
    "component_get_name_signature": "GetComponentName<{0}>()",
    "component_get_name_return": "StringView"
  },

