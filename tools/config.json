{
  "paths": {
    "scene_dep_manager_path": "engine/include/modules/scene/format/scene_dep_manager.hpp",
    "scene_dep_manager_include": "modules/scene/format/scene_dep_manager.hpp",
    "editor_dep_manager_path": "editor/include/editor_dep_manager.hpp",
    "editor_dep_manager_include": "editor_dep_manager.hpp"
  },
  "category_colors": {
    "GENERAL":   "#C8C8C8",
    "TRANSFORM": "#F0C27A",
    "RENDERING": "#7AB8F0",
    "LIGHTNING":  "#F0E97A",
    "PHYSICS":   "#A8F07A",
    "AUDIO":     "#C47AF0"
  },
  "prefixes": ["m", "b"],
  "templates": {
    
    "parse_fn_namespace": "lum::fmt::detail",
    "parse_fn_signature": "Parse{ClassName}( std::vector<FToken>& tokens, int32& i, FParseContext& ctx )",
    "parse_fn_body_open": "detail::ExpectOpeningBracket( tokens, i );",
    "parse_fn_var_name": "component",
    "parse_fn_field": "{Var}.{FieldName} = {Reader}( tokens, i );",
    "parse_fn_add": "ctx.mScene.mEntityMgr.AddComponent( ctx.mEntity, {Var} );",
    "parse_fn_registry": "RegisterComponents( std::unordered_map<uint64, ParseFn>& {Param} )",
    "parse_fn_while_expr": "InBlock( tokens, i )",
    "parse_fn_while_statement": "tokens[i].mValue == \"{Value}\"",
    "parse_fn_token_check": "tokens[i].mType == TokenType::Parameter",
    
    "editor_fn_namespace": "lum::editor",
    "editor_fn_signature": "DrawInspector{ClassName}( ecs::MEntityManager& mgr, EntityID entity )",
    "editor_fn_comp_name": "component",
    "editor_fn_comp_getter": "auto* {Var} = mgr.GetComponent<{ClassName}>( entity );",
    "editor_fn_getter_check": "if(!{Var}) return;",
    "editor_fn_registry": "RegisterEditorComponents( std::unordered_map<uint64, EditorComponentEntry>& {Param} )",
    "editor_fn_registry_add_fn": "[]( ecs::MEntityManager& mgr, EntityID id ) { mgr.AddComponent<{ClassName}>( id ); }",
    "editor_fn_registry_typeid": "GenerateTypeID::Get<{ClassName}>()",
    "editor_fn_registry_remove_fn": "[]( ecs::MEntityManager& mgr, EntityID id ) { mgr.RemoveComponent<{ClassName}>( id ); }",

    "get_parse_name_namespace": "lum::ecs::detail",
    "get_parse_name_signature": "GetComponentParseName<{ClassName}>()",
    "get_parse_name_return": "StringView",

    "get_display_name_namespace": "lum::ecs::detail",
    "get_display_name_signature": "GetComponentDisplayName<{ClassName}>()",
    "get_display_name_return": "StringView",

    "get_category_name_namespace": "lum::ecs::detail",
    "get_category_name_signature": "GetComponentCategoryName<{ClassName}>()",
    "get_category_name_return": "StringView",
    
    "get_category_color_namespace": "lum::editor",
    "get_category_color_signature": "GetCategoryColor(StringView {VariableName})",
    "get_category_color_return": "ImVec4"

  },
  "defaults": {
    "drag_speed": "0.01f",
